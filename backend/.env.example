# ============================================================================
# MAX VPS Backend - Environment Variables Example
# ============================================================================
# Скопируй в .env и заполни реальные значения. НЕ КОММИТЬ .env!
# ============================================================================

# === Application ===
APP_NAME=MAX VPS
APP_ENV=production                  # development | production
DEBUG=False                          # True для verbose logging
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR

# === Server ===
HOST=0.0.0.0
PORT=8000
WORKERS=2                            # Количество uvicorn workers

# === Database (PostgreSQL — локальная, на Server D) ===
POSTGRES_HOST=postgres               # Имя контейнера в docker-compose
POSTGRES_PORT=5432
POSTGRES_DB=maxvps
POSTGRES_USER=maxvps
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://maxvps:change_me@postgres:5432/maxvps

# === JWT Authentication ===
# Генерируй через: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change_me_jwt_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=maxvps.online
JWT_AUDIENCE=maxvps-web

# === Telegram Bot Integration ===
# Тот же TG_TOKEN, что у бота, плюс наш дополнительный handler
TG_BOT_TOKEN=change_me_telegram_bot_token
TG_BOT_USERNAME=MAX_VPS_BOT
# URL нашего backend (для кнопки в боте)
BACKEND_URL=https://maxvps.online
# WebApp URL для Mini App
WEBAPP_URL=https://maxvps.online/app/

# === CORS ===
CORS_ORIGINS=["https://maxvps.online", "https://www.maxvps.online"]
CORS_ALLOW_CREDENTIALS=True

# === Redis (для rate-limit и кэша кодов) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE_AUTH=5         # Попыток ввода кода в минуту с 1 IP
RATE_LIMIT_PER_MINUTE_API=60         # Обычные API запросы
RATE_LIMIT_PER_MINUTE_PAY=10         # Создание платежей

# === Code TTL (код для входа на сайт) ===
AUTH_CODE_TTL_SECONDS=300            # 5 минут
AUTH_CODE_LENGTH=6                   # Длина цифрового кода

# ============================================================================
# 3X-UI PANELS (X-UI API клиент)
# ============================================================================
# Каждый сервер в БД имеет свой api_token/sub_path.
# Здесь — defaults если новый сервер создаётся без credentials.
XUI_DEFAULT_PANEL_URL=https://panel.example.com:2096
XUI_DEFAULT_INBOUND_ID=1
XUI_DEFAULT_API_TOKEN=
XUI_DEFAULT_SUB_PATH=sub

# ============================================================================
# PAYMENT SYSTEMS (13 integrations)
# ============================================================================
# Все ключи опциональны — если пусто, метод скрывается в UI.

# --- Telegram Stars ---
TG_STARS_TOKEN=off                   # 'off' | token

# --- ЮKassa ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://maxvps.online/app/account

# --- ЮMoney ---
YOOMONEY_TOKEN=
YOOMONEY_WALLET=

# --- CryptoBot ---
CRYPTO_BOT_API=

# --- Cryptomus ---
CRYPTOMUS_KEY=
CRYPTOMUS_UUID=
CRYPTOMUS_MERCHANT_ID=

# --- Lava.top ---
LAVA_TOKEN_SECRET=
LAVA_ID_PROJECT=

# --- WATA (Card / SBP / Visa) ---
WATA_TOKEN_CARD=
WATA_TOKEN_SBP=
WATA_TOKEN_VISA=

# --- Heleket ---
HELEKET_KEY=
HELEKET_UUID=

# --- WawaPay ---
WAWA_API_KEY=
WAWA_MERCHANT_ID=

# --- FreeKassa ---
FREEKASSA_MERCHANT_ID=
FREEKASSA_SECRET_WORD_1=
FREEKASSA_SECRET_WORD_2=

# --- KassaSmart ---
KASSASMART_LOGIN=
KASSASMART_PASSWORD=
KASSASMART_SHOP_ID=

# --- Tinkoff ---
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=

# === Webhook URLs (платёжки шлют сюда) ===
PUBLIC_WEBHOOK_BASE=https://maxvps.online

# ============================================================================
# BUSINESS LOGIC
# ============================================================================

# Тарифы (в копейках через запятую)
MONTH_COST=15000,39000,80000,160000   # 1 мес / 3 мес / 6 мес / 12 мес

# Trial
TRIAL_PERIOD_DAYS=1
TRIAL_LIMIT_GB=2

# Limits
LIMIT_IP=5
LIMIT_GB=500

# Реферальная программа
REFERRAL_PERCENT=20
REFERRAL_MIN_WITHDRAWAL=500

# Free server (если есть)
FREE_SERVER_ENABLED=False
FREE_SERVER_LIMIT_GB=5

# ============================================================================
# SECURITY
# ============================================================================
SECRET_KEY=change_me_secret_key_for_cryptography
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=lax

# Trusted hosts
TRUSTED_HOSTS=["maxvps.online", "www.maxvps.online", "localhost"]

# CSRF
CSRF_SECRET=change_me_csrf_secret

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# ============================================================================
# DEPLOYMENT
# ============================================================================
DOCKER_IMAGE=maxvps-backend
DOCKER_TAG=latest
GIT_COMMIT=
GIT_BRANCH=main
