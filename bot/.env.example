# ============================================================================
# MAX VPS Bot (Reference) — Env Example
# ============================================================================
# Это .env.example для бота, как ОРИГИНАЛ в /root/VPNFlashBot/.env
# ВНИМАНИЕ: бот НЕ НАШ, он на Server B (87.121.217.36) у пользователя.
# Этот файл — только справочник какие переменные были у бота,
# чтобы наш FastAPI backend мог с ним совместимо работать.
# ============================================================================

# === Telegram Bot (prod на Server B) ===
ADMIN_TG_ID=your_admin_tg_id
TG_TOKEN=your_bot_token
TG_STARS=off
TG_STARS_DEV=run
NAME=VPNHubBot

# === Languages ===
LANGUAGES=ru

# === Channel (для проверки подписки) ===
CHECK_FOLLOW=True
ID_CHANNEL=@your_channel
LINK_CHANNEL=https://t.me/your_channel
NAME_CHANNEL=Your Channel Name

# === Database (PostgreSQL на Server B, в Docker) ===
POSTGRES_DB=VPNHubBotDB
POSTGRES_USER=vpnuser
POSTGRES_PASSWORD=vpnpass123

# === Pricing ===
MONTH_COST=15000,39000,80000,160000
TRIAL_PERIOD=86400
FREE_SWITCH_LOCATION=1
PRICE_SWITCH_LOCATION=0
UTC_TIME=0

# === Limits ===
LIMIT_IP=5
LIMIT_GB=500

# === Referral ===
REFERRAL_DAY=30
REFERRAL_PERCENT=20
MINIMUM_WITHDRAWAL_AMOUNT=500

# === pgAdmin ===
PGADMIN_DEFAULT_EMAIL=admin@vpnflash.com
PGADMIN_DEFAULT_PASSWORD=adminpass123

# === Free Server ===
FREE_SERVER=0
LIMIT_GB_FREE=0
SHOW_DONATE=False

# === Import (только при миграции) ===
IMPORT_DB=0
DEBUG=False
FONT_TEMPLATE=

# === Payment Systems (опционально) ===
YOOMONEY_TOKEN=
YOOMONEY_WALLET=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
CRYPTOMUS_KEY=
CRYPTOMUS_UUID=
CRYPTO_BOT_API=
LAVA_TOKEN_SECRET=
LAVA_ID_PROJECT=
WATA_TOKEN_CARD=
WATA_TOKEN_SBP=
WATA_TOKEN_VISA=
HELEKET_KEY=
HELEKET_UUID=

# === NATS (внутренний message broker) ===
NATS_URL=nats://nats:4222
